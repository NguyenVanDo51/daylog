{
  "expo": {
    "name": "Daylog",
    "slug": "daylog",
    "version": "1.0.0",
    "scheme": "daylog",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.andynguyen.daylog",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Cho phép chụp ảnh và quay video kỷ niệm của bé",
        "NSPhotoLibraryUsageDescription": "Cho phép xóa ảnh đã được lưu an toàn trên ứng dụng",
        "NSPhotoLibraryAddUsageDescription": "Cho phép lưu ảnh vào thư viện",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "sentryDsn": "",
      "router": {},
      "eas": {
        "projectId": "c4326eda-3dde-4785-919a-76440eb88f28"
      }
    },
    "plugins": [
      [
        "@sentry/react-native",
        {
          "organization": "",
          "project": ""
        }
      ],
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7C5CBF"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Cho phép chụp ảnh và quay video kỷ niệm của bé"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Cho phép truy cập thư viện ảnh để thêm vào nhật ký"
        }
      ],
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.226720896102-vso7m6bh015b124v87gds9krpsq4tljt"
        }
      ],
      "expo-image",
      "expo-font",
      "expo-localization",
      "expo-media-library",
      "expo-video",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F8F4FF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "android": {
      "package": "com.andynguyen.daylog",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    }
  }
}
